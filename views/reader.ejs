<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chapter <%= chapter.chapter_number %>: <%= chapter.title %> | FILM Series</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="reader-wrapper">
    <!-- Top header -->
    <div class="reader-header">
      <h1>Chapter <%= chapter.chapter_number %>: <%= chapter.title %></h1>
      <div class="reader-nav">
        <% if (prevChapter) { %>
          <a href="/chapters/<%= prevChapter.id %>" class="btn btn-sm btn-outline">&larr; Prev Chapter</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">&larr; Prev Chapter</span>
        <% } %>
        <a href="/chapters" class="btn btn-sm">All Chapters</a>
        <% if (nextChapter) { %>
          <a href="/chapters/<%= nextChapter.id %>" class="btn btn-sm btn-outline">Next Chapter &rarr;</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">Next Chapter &rarr;</span>
        <% } %>
      </div>
      <% if (pages.length > 0) { %>
        <div class="reader-page-info"><%= pages.length %> page<%= pages.length !== 1 ? 's' : '' %></div>
      <% } %>
    </div>

    <!-- Pages (webtoon style) -->
    <% if (pages.length > 0) { %>
      <div class="webtoon-reader">
        <% pages.forEach((page, idx) => { %>
          <div class="webtoon-page" id="page-<%= page.page_number %>">
            <img src="<%= page.image_path %>" alt="Page <%= page.page_number %>" loading="<%= idx < 3 ? 'eager' : 'lazy' %>">
            <div class="page-number-indicator"><%= page.page_number %> / <%= pages.length %></div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>This chapter is being prepared. Check back soon!</p>
      </div>
    <% } %>

    <!-- Bottom navigation -->
    <div class="reader-bottom-nav">
      <% if (prevChapter) { %>
        <a href="/chapters/<%= prevChapter.id %>" class="btn btn-lg btn-outline">&larr; Previous Chapter</a>
      <% } else { %>
        <span></span>
      <% } %>
      <% if (nextChapter) { %>
        <a href="/chapters/<%= nextChapter.id %>" class="btn btn-lg btn-accent">Next Chapter &rarr;</a>
      <% } %>
    </div>

    <!-- Scroll to top -->
    <button class="scroll-top-btn" id="scrollTopBtn" title="Scroll to top">&#8679;</button>

    <!-- Reviews Section -->
    <div class="reader-reviews-container">
      <div class="reviews-section" id="reviews">
        <h2 class="reviews-title">
          Reviews
          <% if (rating.count > 0) { %>
            <span class="rating-summary">
              <span class="stars-display">
                <% for (let i = 1; i <= 5; i++) { %>
                  <span class="star <%= i <= Math.round(rating.avg) ? 'star-filled' : 'star-empty' %>">&#9733;</span>
                <% } %>
              </span>
              <%= rating.avg %> / 5 (<%= rating.count %> review<%= rating.count !== 1 ? 's' : '' %>)
            </span>
          <% } %>
        </h2>

        <div class="review-form-card">
          <h3>Leave a Review</h3>
          <form method="POST" action="/chapters/<%= chapter.id %>/review">
            <div class="star-rating-input">
              <label>Your Rating:</label>
              <div class="star-picker">
                <% for (let i = 5; i >= 1; i--) { %>
                  <input type="radio" name="stars" value="<%= i %>" id="star<%= i %>" required>
                  <label for="star<%= i %>" class="star-label">&#9733;</label>
                <% } %>
              </div>
            </div>
            <div class="form-group">
              <label for="review-text">Your thoughts (optional)</label>
              <textarea id="review-text" name="text" rows="3" placeholder="What did you think of this chapter?"></textarea>
            </div>
            <button type="submit" class="btn btn-sm">Submit Review</button>
          </form>
        </div>

        <% if (reviews.length === 0) { %>
          <p class="empty-state" style="padding: 20px;">No reviews yet. Be the first!</p>
        <% } else { %>
          <div class="reviews-list">
            <% reviews.forEach(rev => { %>
              <div class="review-card">
                <div class="review-header">
                  <strong class="review-user"><%= rev.username %></strong>
                  <span class="stars-display">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <span class="star <%= i <= rev.rating ? 'star-filled' : 'star-empty' %>">&#9733;</span>
                    <% } %>
                  </span>
                  <span class="review-date"><%= new Date(rev.created_at).toLocaleDateString() %></span>
                  <% if (user && user.role === 'admin') { %>
                    <form method="POST" action="/admin/reviews/delete/<%= rev.id %>" style="display:inline; margin-left:auto;">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this review?')">Delete</button>
                    </form>
                  <% } %>
                </div>
                <% if (rev.text) { %>
                  <p class="review-text"><%= rev.text %></p>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
  (function() {
    const btn = document.getElementById('scrollTopBtn');
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 600);
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
  </script>

  <%- include('partials/footer') %>
</body>
</html>
